# -----------------------------------------------------------------------------
# Vercel 환경변수 (Vercel 대시보드에 동일 이름으로 등록)
# -----------------------------------------------------------------------------

# 어드민 페이지에서 사용할 비밀번호 (충분히 길고 어렵게)
ADMIN_PASSWORD=your-strong-admin-password

# GitHub 저장소 정보
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=rustic-collage
GITHUB_BRANCH=main

# GitHub Personal Access Token (Fine-grained, repo write 권한)
# 발급: https://github.com/settings/personal-access-tokens
# 권한: Contents - Read and write
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
